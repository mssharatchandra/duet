# Duet environment configuration
# Copy to .env and fill in. Never commit .env.
# Everything here is optional until the phase that needs it — Phase 1 runs fully local with no keys.

# --- Phase 2: async reasoning layer ---
# The one paid API dependency we accept on principle.
GEMINI_API_KEY=
# Optional override; default is gemini-3.1-flash-lite (see DECISIONS.md 0005)
# REASONING_MODEL=gemini-3.5-flash

# --- Phase 3: observability (self-hosted Langfuse; keys come from your own instance) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Phase 3/4: local infra (docker-compose defaults) ---
DATABASE_URL=postgresql://duet:duet@localhost:5432/duet
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=

# --- Phase 4: demo limits ---
SESSION_MAX_SECONDS=240          # hard server-side cap per demo call
SESSIONS_PER_EMAIL_PER_DAY=1
