{
  "uid": "duet-bench",
  "title": "Duet — benchmark & calls",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Duet vs cascaded baseline (all runs)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "postgres", "uid": "duet-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT mode, count(*) AS calls, round(avg(takeover_rate)::numeric, 3) AS takeover_rate, round(avg(overlap_ratio)::numeric, 3) AS overlap_ratio, round(avg(response_latency_ms_p50)::numeric) AS handoff_p50_ms, round(avg(response_latency_ms_p95)::numeric) AS handoff_p95_ms, round(avg(cost_per_min_usd)::numeric, 4) AS usd_per_min FROM calls GROUP BY mode ORDER BY mode;"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Handoff latency p95 (ms) per call",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "duet-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT ts AS \"time\", response_latency_ms_p95 AS value, mode AS metric FROM calls ORDER BY ts;"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Takeover rate per call",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "duet-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT ts AS \"time\", takeover_rate AS value, mode AS metric FROM calls ORDER BY ts;"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reasoning cost (USD, all calls)",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 5 },
      "datasource": { "type": "postgres", "uid": "duet-pg" },
      "targets": [
        { "refId": "A", "format": "table", "rawSql": "SELECT coalesce(sum(reasoning_cost_usd), 0) FROM calls;" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total calls",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 5 },
      "datasource": { "type": "postgres", "uid": "duet-pg" },
      "targets": [{ "refId": "A", "format": "table", "rawSql": "SELECT count(*) FROM calls;" }]
    }
  ]
}
